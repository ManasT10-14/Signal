# Environment Configuration — copy to .env and fill in values
# DO NOT commit .env to version control

# ── GCP / Vertex AI ──────────────────────────────────────────────────────────
# Required for LLM calls via Vertex AI
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# Vertex AI uses Application Default Credentials (ADC)
# Run: gcloud auth application-default login
# Or set GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ── Gemini (legacy direct API — used if VERTEX_ENABLED=false) ───────────────
GEMINI_API_KEY=your-gemini-api-key
VERTEX_ENABLED=true

# ── Database ────────────────────────────────────────────────────────────────
# Use DATABASE_URL for Postgres, or SQLITE_URL for local development
# SQLite (no install needed — for quick experimentation only)
SQLITE_URL=sqlite+aiosqlite:///./signal_dev.db

# Postgres (production)
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/signal
DATABASE_URL=

# ── Redis / ARQ Queue ─────────────────────────────────────────────────────
# Use REDIS_URL for Redis, or QUEUE_MODE=memory for local development
QUEUE_MODE=memory
REDIS_URL=redis://localhost:6379/0

# ── AWS S3 ────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=signal-audio

# ── AssemblyAI (ASR) ───────────────────────────────────────────────────────
ASSEMBLYAI_API_KEY=

# ── App Config ─────────────────────────────────────────────────────────────
SIGNAL_ENV=development
SIGNAL_DEBUG=true
SIGNAL_LLM_MODEL=gemini-2.5-flash

# ── Langfuse (Observability) ───────────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
